# AssetFlow OS — Backend Environment Variables

# NeonDB (Serverless PostgreSQL) connection string
# Get yours from https://neon.tech
DATABASE_URL=postgresql://user:password@ep-example-123.us-east-2.aws.neon.tech/assetflow?sslmode=require

# JWT secret — generate a strong 512-bit key:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# JWT token expiry duration
JWT_EXPIRES_IN=7d

# Server port (default: 3001)
PORT=3001